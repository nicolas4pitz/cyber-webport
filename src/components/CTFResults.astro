---
interface CTFResult {
  title: string;
  date: string;
  score: string;
  rank: string;
  description: string;
}

interface Props {
  ctfResults?: CTFResult[]
  itemsPerPage?: number;
}

const { ctfResults = [], itemsPerPage = 10 } = Astro.props;
const totalPages = Math.ceil(ctfResults.length / itemsPerPage);
---

<div class="ctf-container" data-items-per-page={itemsPerPage} data-total-pages={totalPages}>
  {ctfResults?.map((ctf, index) => (
    <div class="ctf-card" data-index={index}>
      <div class="ctf-header">
        <h3 class="ctf-title">{ctf.title}</h3>
        <span class="ctf-date">{ctf.date}</span>
      </div>
      <div class="ctf-content">
        <p class="ctf-description">{ctf.description}</p>
        <div class="ctf-stats">
          <div class="stat">
            <span class="stat-label">Score</span>
            <span class="stat-value">{ctf.score}</span>
          </div>
          <div class="stat">
            <span class="stat-label">Rank</span>
            <span class="stat-value">{ctf.rank}</span>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

{totalPages > 1 && (
  <div class="pagination" id="pagination">
    <button class="pagination-btn pagination-prev" id="prev-btn">← Previous</button>
    <span class="page-info"><span id="current-page">1</span> / {totalPages}</span>
    <button class="pagination-btn pagination-next" id="next-btn">Next →</button>
  </div>
)}

<script>
  const container = document.querySelector('.ctf-container');
  if (!container) throw new Error('Container não encontrado');
  
  const itemsPerPage = parseInt(container.dataset.itemsPerPage || '10', 10);
  const totalPages = parseInt(container.dataset.totalPages || '1', 10);
  const ctfCards = container.querySelectorAll('.ctf-card');
  
  let currentPage = 1;
  
  function showPage(page: number) {
    const start = (page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    
    ctfCards.forEach((card, index) => {
      card.style.display = (index >= start && index < end) ? 'block' : 'none';
    });
    
    // Atualizar página atual
    currentPage = page;
    const currentPageSpan = document.getElementById('current-page');
    if (currentPageSpan) currentPageSpan.textContent = String(page);
    
    // Atualizar estado dos botões
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    if (prevBtn) prevBtn.disabled = page === 1;
    if (nextBtn) nextBtn.disabled = page === totalPages;
  }
  
  // Event listeners dos botões
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  
  if (prevBtn) {
    prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (currentPage > 1) showPage(currentPage - 1);
    });
  }
  
  if (nextBtn) {
    nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (currentPage < totalPages) showPage(currentPage + 1);
    });
  }
  
  // Mostrar primeira página
  showPage(1);
</script>

<style>
  .ctf-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .ctf-card {
    border: 1px solid var(--border-color);
    padding: 1rem;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .ctf-card:hover {
    background-color: var(--hover-color);
    border-color: var(--accent-color);
  }

  .ctf-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }

  .ctf-title {
    margin: 0;
    font-size: 1.1rem;
  }

  .ctf-date {
    font-size: 0.85rem;
    opacity: 0.8;
    flex-shrink: 0;
  }

  .ctf-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ctf-description {
    margin: 0;
    font-size: 0.95rem;
  }

  .ctf-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    background-color: var(--hover-color);
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .stat-label {
    font-weight: 600;
    opacity: 0.8;
  }

  .stat-value {
    font-weight: bold;
    color: var(--accent-color);
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .pagination-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    background-color: transparent;
    cursor: pointer;
    border-radius: 4px;
  }

  .pagination-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 0.9rem;
  }
</style>
