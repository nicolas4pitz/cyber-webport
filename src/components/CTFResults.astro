---
interface CTFResult {
  title: string;
  date: string;
  score: string;
  rank: string;
  description: string;
}

interface Props {
  ctfResults?: CTFResult[]
  itemsPerPage?: number;
  max?: number;
}

const { ctfResults = [], itemsPerPage = 10, max = 2 } = Astro.props;
const totalPages = Math.ceil(ctfResults.length / itemsPerPage);
---

<div class="ctf-container" data-items-per-page={itemsPerPage} data-total-pages={totalPages}>
  {ctfResults?.slice(0, max).map((ctf, index) => (
    <div class="ctf-card" data-index={index}>
      <div class="ctf-header">
        <h3 class="ctf-title">{ctf.title}</h3>
        <span class="ctf-date">{ctf.date}</span>
      </div>
      <div class="ctf-content">
        <p class="ctf-description">{ctf.description}</p>
        <div class="ctf-stats">
          <div class="stat">
            <span class="stat-label">Score</span>
            <span class="stat-value">{ctf.score}</span>
          </div>
          <div class="stat">
            <span class="stat-label">Rank</span>
            <span class="stat-value">{ctf.rank}</span>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .ctf-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .ctf-card {
    transition: all 0.3s ease;
  }

  .ctf-card:hover {
  }

  .ctf-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ctf-title {
    margin: 0;
    font-size: 1.1rem;
    color: var(--pink);
  }

  .ctf-date {
    font-size: 0.85rem;
    opacity: 0.7;
    color: var(--text);
    flex-shrink: 0;
  }

  .ctf-content {
    display: flex;
    flex-direction: column;
  }

  .ctf-description {
    margin: 0;
    font-size: 13px;
  }

  .ctf-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
  }

  .stat-label {
    font-weight: 600;
    opacity: 0.8;
  }

  .stat-value {
    font-weight: bold;
    color: var(--pink-glow);
    opacity: 0.8;
  }
</style>
