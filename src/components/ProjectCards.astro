---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects?: CollectionEntry<"blog">[]
}

const { projects = [] } = Astro.props;
---

<div class="projects-container">
  {projects?.slice(0, 2).map((project) => (
    <a href={`/projects/${project.data.slug}`} class="project-link">
      <div class="project-card">
        <div class="project-header">
          <h3 class="project-title">{project.data.title}</h3>
          <div class="project-links">
            {project.data.githubURL && (
              <a href={project.data.githubURL} target="_blank" rel="noopener noreferrer" class="project-icon" title="GitHub">
                <span>→ GitHub</span>
              </a>
            )}
            {project.data.liveSiteURL && (
              <a href={project.data.liveSiteURL} target="_blank" rel="noopener noreferrer" class="project-icon" title="Live Site">
                <span>→ Live</span>
              </a>
            )}
          </div>
        </div>
        <div class="project-tags">
          {project.data.tags?.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <div class="project-footer">
          <p class="project-description">{project.data.description}</p>
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .projects-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .project-link {
    text-decoration: none;
    color: inherit;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .project-card:hover {
    background-color: var(--hover-color);
    border-color: var(--accent-color);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-title {
    margin: 0;
    font-size: 1.1rem;
    color: var(--pink);
    font-weight: 600;
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .project-icon {
    font-size: 0.8rem;
    padding: 0.25rem 0.5rem;
    background-color: var(--accent-color);
    color: var(--pink-glow);
    border-radius: 2px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .project-icon:hover {
    opacity: 0.8;
  }

  .project-tags {
    display: flex;
    gap: 8px;
    
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.7;
    border-right: 1px dashed var(--pink-dim);
    border-left: 1px dashed var(--pink-dim);
    padding: 0px 1px 0px 1px;
    border-radius: 2px;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
  }

  .project-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.4;
    flex: 1;
  }

  .project-link-indicator {
    flex-shrink: 0;
    color: var(--accent-color);
  }
</style>
