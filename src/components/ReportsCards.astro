---
interface Report {
  title: string;
  slug: string;
  type: string;
  description: string;
}

interface Props {
  reports?: Report[]
}

const { reports = [] } = Astro.props;
---

<div class="reports-container">
  {reports?.map((report) => (
    <a href={`/reports/${report.slug}`} class="report-link">
      <div class="report-card">
        <div class="report-header">
          <h3 class="report-title">{report.title}</h3>
          <span class="report-type">{report.type}</span>
        </div>
        <div class="report-footer">
          <p class="report-description">{report.description}</p>
          <span class="report-link-indicator">→</span>
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .reports-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .report-link {
    text-decoration: none;
    color: inherit;
  }

  .report-card {
    border: 1px solid var(--border-color);
    padding: 1.25rem;
    border-radius: 4px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .report-card:hover {
    background-color: var(--hover-color);
    border-color: var(--accent-color);
  }

  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .report-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .report-type {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--accent-color);
    color: var(--bg);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .report-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
  }

  .report-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.4;
    flex: 1;
  }

  .report-link-indicator {
    flex-shrink: 0;
    color: var(--accent-color);
  }
</style>
