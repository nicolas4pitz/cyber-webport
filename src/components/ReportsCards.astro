---
interface Report {
  title: string;
  slug: string;
  type: string;
  description: string;
}

interface Props {
  reports?: Report[],
  max?: number
}

const { reports = [], max = 2 } = Astro.props;
---

<div class="reports-container">
  {reports?.slice(0, max).map((report) => (
    <a href={`/reports/${report.slug}`} class="report-link">
      <div class="report-card">
        <div class="report-header">
          <h3 class="report-title">{report.title}</h3>
          <span class="report-type">{report.type}</span>
        </div>
        <div class="report-footer">
          <p class="report-description">{report.description}</p>
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .reports-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .report-link {
    text-decoration: none;
    color: inherit;
  }

  .report-card {
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .report-card:hover {
    background-color: var(--hover-color);
    border-color: var(--accent-color);
  }

  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .report-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--pink);
  }

  .report-type {
    font-size: 0.8rem;
    color: var(--pink-glow);
    flex-shrink: 0;
  }

  .report-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .report-description {
    margin: 0;
    line-height: 1.4;
    flex: 1;
    font-size: 13px;
  }

  .report-link-indicator {
    flex-shrink: 0;
    color: var(--accent-color);
  }
</style>
