---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('blog');
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"blog">;
}

const { project } = Astro.props;

const { Content } = await render(project);
---

<Layout>
  <main class="wrap project-detail">
    <a href="/" class="back-link">← Back</a>
    
    <article>
      <header class="project-header">
        <h1>{project.data.title}</h1>
        <div class="project-meta">
          <span class="date">{project.data.date}</span>
          <div class="tags">
            {project.data.tags?.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
        <div class="project-links">
          {project.data.githubURL && (
            <a href={project.data.githubURL} target="_blank" rel="noopener noreferrer" class="btn btn-github">
              → GitHub Repository
            </a>
          )}
          {project.data.liveSiteURL && (
            <a href={project.data.liveSiteURL} target="_blank" rel="noopener noreferrer" class="btn btn-live">
              → View Live Site
            </a>
          )}
        </div>
      </header>

      <div class="project-content">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .wrap {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 90px 20px 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
    color: var(--text);
  }

  .back-link:hover {
    color: var(--pink-dim);
  }

  .project-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .project-header h1 {
    margin: 0 0 1rem 0;
    font-size: 2rem;
    color: var(--pink);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--accent-color);
    border-radius: 2px;
    font-size: 0.8rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--pink);
    transition: all 0.3s ease;
  }

  .btn:hover {
    color: var(--pink-dim);
  }

  .project-content {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.6;
  }

  .project-content :global(p) {
    margin: 1rem 0;
  }

  .project-content :global(h2) {
    margin: 1.5rem 0 0.5rem 0;
    font-size: 1.3rem;
  }

  .project-content :global(h3) {
    margin: 1rem 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .project-content :global(li) {
    margin: 0.5rem 0;
  }

  .project-content :global(code) {
    background-color: var(--hover-color);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
  }

  .project-content :global(pre) {
    background-color: var(--hover-color);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1rem 0;
  }
</style>
