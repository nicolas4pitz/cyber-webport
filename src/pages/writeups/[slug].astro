---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('writeups');
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"writeups">;
}

const { project } = Astro.props;

const { Content } = await render(project);
---

<Layout>
  <main class="wrap report-detail">
    <a href="/" class="back-link">← Back</a>
    
    <article>
      <header class="report-header">
        <h1>{project.data.title}</h1>
        <div class="report-meta">
          <span class="type">{project.data.description}</span>
        </div>
      </header>

      <div class="report-content">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .wrap {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 90px 20px 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
    color: var(--text);
  }

  .back-link:hover {
    color: var(--pink-dim);
  }

  .report-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .report-header h1 {
    margin: 0 0 1rem 0;
    font-size: 2rem;
    color: var(--pink);
  }

  .report-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .type {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--accent-color);
    border-radius: 2px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .report-content {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
    max-width: 860px;
  }

  .report-section {
    margin: 2rem 0;
  }

  .report-content p {
    margin: 1rem 0;
  }

  .report-content h2 {
    margin: 1.5rem 0 0.75rem 0;
    font-size: 1.3rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .report-content h3 {
    margin: 1rem 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .report-content ul,
  .report-content ol {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .report-content li {
    margin: 0.5rem 0;
  }

  .report-content code {
    background-color: var(--hover-color);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
  }

  .report-content pre {
    background-color: var(--hover-color);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1rem 0;
  }

  /* Aplicar estilos no markdown */
  :global(.report-content) {

    p {
      font-family: var(--mono);
      background-color: rgba(0, 0, 0, 0.452);
      
    }

  
    p::before{
      content: ">";
    }

    img{
      max-width: 100% !important;
      width: auto !important;
      margin: 1.5rem 0 !important;
    }


  }
</style>
